CREATE_SCHEMA=false

# Bootstrap sync: pull all messages from server first (before normal sync). Used by store-clean-setup so new store gets server state (e.g. 14k messages) instead of overwriting server merkle.
# When SYNC_BOOTSTRAP_URL is set, store runs one bootstrap sync at startup and does not print "Store is running" until it completes.
SYNC_BOOTSTRAP_URL=http://localhost:3002
SYNC_BOOTSTRAP_USERNAME=admin@dnamicro.com
SYNC_BOOTSTRAP_PASSWORD=ch@ng3m3Pl3@s3!!

