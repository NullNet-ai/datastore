# Simple Dockerfile for testing make commands across different Linux distributions

# Stage 1: Ubuntu test
FROM ubuntu:22.04 AS ubuntu-test
ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=UTC

RUN ln -snf /usr/share/zoneinfo/$TZ /etc/localtime && echo $TZ > /etc/timezone

RUN apt-get update && apt-get install -y \
    make \
    git \
    sudo \
    curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY . .
RUN cp .env-sample .env && \
    sed -i 's/localhost/host.docker.internal/g' .env

RUN make help
RUN make install

CMD ["make", "store"]

# Stage 2: Fedora test (Red Hat family)
FROM fedora:latest AS centos-test
ENV TZ=UTC

RUN ln -snf /usr/share/zoneinfo/$TZ /etc/localtime && echo $TZ > /etc/timezone

RUN dnf update -y && dnf install -y \
    @development-tools \
    make \
    git \
    sudo \
    curl

WORKDIR /app
COPY . .
RUN cp .env-sample .env && \
    sed -i 's/localhost/host.docker.internal/g' .env

RUN make help
RUN make install

CMD ["make", "store"]

# Stage 3: Alpine test (lightweight)
FROM alpine:latest AS arch-test
ENV TZ=UTC

RUN ln -snf /usr/share/zoneinfo/$TZ /etc/localtime && echo $TZ > /etc/timezone

RUN apk update && apk add --no-cache \
    build-base \
    make \
    git \
    sudo \
    curl \
    bash

WORKDIR /app
COPY . .
RUN cp .env-sample .env && \
    sed -i 's/localhost/host.docker.internal/g' .env

RUN make help
RUN make install

CMD ["make", "store"]

# Final stage: Ubuntu as default
FROM ubuntu-test AS final
CMD ["make", "help"]

