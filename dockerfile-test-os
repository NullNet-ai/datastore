# Simple Dockerfile for testing make commands across different Linux distributions

# Stage 1: Ubuntu test
FROM ubuntu:22.04 AS ubuntu-test
ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=UTC

RUN ln -snf /usr/share/zoneinfo/$TZ /etc/localtime && echo $TZ > /etc/timezone

RUN apt-get update && apt-get install -y \
    make \
    git \
    sudo \
    curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY . .
RUN cp .env-sample .env && \
    sed -i 's/localhost/host.docker.internal/g' .env

RUN make help
RUN make install

CMD ["make", "store"]

# Stage 2: CentOS test
FROM centos:latest AS centos-test
RUN yum update -y && yum install -y \
    make \
    git \
    sudo \
    curl

WORKDIR /app
COPY . .
RUN cp .env-sample .env && \
    sed -i 's/localhost/host.docker.internal/g' .env

RUN make help
RUN make install

CMD ["make", "store"]

# Stage 3: Arch test
FROM archlinux:latest AS arch-test
RUN pacman -Syu --noconfirm && \
    pacman -S --noconfirm \
    make \
    git \
    sudo \
    curl

WORKDIR /app
COPY . .
RUN cp .env-sample .env && \
    sed -i 's/localhost/host.docker.internal/g' .env

RUN make help
RUN make install

CMD ["make", "store"]

# Final stage: Ubuntu as default
FROM ubuntu-test AS final
CMD ["make", "help"]

