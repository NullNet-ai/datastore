{
    "rust-analyzer.checkOnSave": false,
    "rust-analyzer.linkedProjects": [
        "./Cargo.toml"
    ],
    "rust-analyzer.cargo.buildScripts.enable": true,
    "rust-analyzer.procMacro.enable": true,
    "rust-analyzer.cargo.buildScripts.useRustcWrapper": true,
    "rust-analyzer.diagnostics.enable": true,
    "rust-analyzer.inlayHints.parameterHints.enable": true,
    "rust-analyzer.inlayHints.typeHints.enable": true,
    "rust-analyzer.lens.enable": true,
    "rust-analyzer.hover.actions.enable": true,
    "rust-analyzer.hover.actions.implementations.enable": true,
    "rust-analyzer.hover.actions.references.enable": true,
    "rust-analyzer.hover.actions.run.enable": true,
    "rust-analyzer.hover.actions.debug.enable": true,
    "rust-analyzer.server.extraEnv": {
        "PROTOC": "/opt/homebrew/bin/protoc"
    },
    "rust-analyzer.runnables.extraEnv": {
        "PATH": "${env:PATH}:${env:HOME}/.cargo/bin",
        "PROTOC": "/opt/homebrew/bin/protoc"
    },
    "rust-analyzer.runnables.extraTestBinaryArgs": ["--nocapture", "--exact"],
    "terminal.integrated.env.osx": {
        "PROTOC": "/opt/homebrew/bin/protoc",
        "PATH": "${env:PATH}:${env:HOME}/.cargo/bin"
    },
    "terminal.integrated.defaultProfile.osx": "zsh",
    "terminal.integrated.profiles.osx": {
        "zsh": { "path": "/bin/zsh" },
        "bash": { "path": "/bin/bash" }
    },
    "terminal.explorerKind": "external",
    "files.watcherExclude": {
        "**/target/**": true,
        "**/.git/**": true
    },
    "search.exclude": {
        "**/target/**": true
    },
    "workbench.colorTheme": "Default Dark+",
    "workbench.colorCustomizations": {
        "editor.background": "#111115",
        "sideBar.background": "#0a0404",
        "panel.background": "#1d1d24",
        "activityBar.background": "#0e0e11",
        "activityBar.foreground": "#d9d9d9",
        "activityBarBadge.background": "#8b0000",
        "activityBarBadge.foreground": "#ffffff",
        "titleBar.activeBackground": "#251818",
        "titleBar.activeForeground": "#d9d9d9",
        "titleBar.inactiveBackground": "#0e0e11",
        "titleBar.inactiveForeground": "#bdbdbd",
        "statusBar.background": "#0e0e11",
        "statusBar.noFolderBackground": "#0e0e11",
        "statusBar.debuggingBackground": "#1a0c0c",
        "statusBar.foreground": "#d9d9d9",
        "button.background": "#8b0000",
        "button.foreground": "#ffffff",
        "badge.background": "#8b0000",
        "badge.foreground": "#ffffff",
        "focusBorder": "#b71c1c",
        "list.activeSelectionBackground": "#1a1a1d",
        "list.activeSelectionForeground": "#e6e6e6",
        "list.hoverBackground": "#141416",
        "list.focusOutline": "#b71c1c",
        "editorCursor.foreground": "#d32f2f",
        "editor.selectionBackground": "#2a0f12",
        "editor.selectionHighlightBackground": "#2a0f1260",
        "editorLineNumber.foreground": "#6b6b6b"
    },
    "[rust]": {
        "editor.defaultFormatter": "rust-lang.rust-analyzer",
        "editor.formatOnSave": true
    }
}
