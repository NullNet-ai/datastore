{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "cargo test",
            "type": "shell",
            "command": "bash",
            "args": ["${workspaceFolder}/.vscode/vscode_test_runner.sh", "cargo", "test"],
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": [
                "$rustc"
            ],
            "options": {
                "env": {
                    "PROTOC": "/opt/homebrew/bin/protoc"
                }
            }
        },
        {
            "label": "cargo test specific",
            "type": "shell",
            "command": "bash",
            "args": ["${workspaceFolder}/.vscode/vscode_test_runner.sh", "cargo", "test", "--package", "store", "--bin", "store", "--all-features", "--", "${input:testName}", "--exact", "--nocapture", "--ignored"],
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": [
                "$rustc"
            ],
            "options": {
                "env": {
                    "PROTOC": "/opt/homebrew/bin/protoc"
                }
            }
        },
        {
            "label": "cargo check",
            "type": "shell",
            "command": "bash",
            "args": ["${workspaceFolder}/.vscode/vscode_test_runner.sh", "cargo", "check"],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": [
                "$rustc"
            ],
            "options": {
                "env": {
                    "PROTOC": "/opt/homebrew/bin/protoc"
                }
            }
        }
    ],
    "inputs": [
        {
            "id": "testName",
            "type": "promptString",
            "description": "Enter the test name (e.g., controllers::store_controller_test::tests::should_use_contacts_filter_with_nested_join_scenario)"
        }
    ]
}