#!/bin/bash

# Post-checkout hook to automatically set up other hooks
# This runs after git clone, git checkout, and git pull

# Only run setup if we're in the main working tree (not during rebase, etc.)
if [ "$3" = "1" ]; then
    echo "Setting up development environment..."
    
    # Get the repository root
    REPO_ROOT="$(git rev-parse --show-toplevel)"
    
    # Run the setup script if it exists
    if [ -f "$REPO_ROOT/scripts/setup-hooks.sh" ]; then
        "$REPO_ROOT/scripts/setup-hooks.sh"
    fi
fi