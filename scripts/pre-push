#!/bin/bash

# Pre-push hook to ensure committed code is formatted before pushing

echo "Checking formatting of committed code..."

# Check if there are any uncommitted changes in tracked files
if ! git diff --quiet; then
    echo "❌ Error: You have uncommitted changes in tracked files."
    echo "Please commit all changes before pushing:"
    echo "  git add <changed_files>"
    echo "  git commit -m 'Your commit message'"
    echo "This ensures that all code is properly formatted and committed before pushing."
    exit 1
fi

# Check if there are any staged changes that need to be committed
if ! git diff --cached --quiet; then
    echo "❌ You have staged changes. Please commit them before pushing."
    exit 1
fi

# Get the repository root
REPO_ROOT="$(git rev-parse --show-toplevel)"

# Get list of Rust files from the latest commit, but only from bin/store and bin/server directories, excluding generated files
RUST_FILES=$(git show --name-only --pretty=format: HEAD | grep '\.rs$' | grep -E '^bin/(store|server)/' | grep -v '/src/generated/' | tr '\n' ' ')

# Check formatting of committed Rust files
if [ -n "$RUST_FILES" ]; then
    # Create a temporary directory to check out committed files
    TEMP_DIR=$(mktemp -d)
    trap "rm -rf $TEMP_DIR" EXIT
    
    # Extract committed files to temp directory
    for file in $RUST_FILES; do
        if [ -f "$REPO_ROOT/$file" ]; then
            mkdir -p "$TEMP_DIR/$(dirname "$file")"
            git show "HEAD:$file" > "$TEMP_DIR/$file" 2>/dev/null || continue
        fi
    done
    
    # Check formatting of the committed files
    cd "$TEMP_DIR"
    if ! cargo fmt --check $RUST_FILES 2>/dev/null; then
        echo "❌ Committed code is not properly formatted!"
        echo "The following files in your latest commit have formatting issues:"
        cargo fmt --check $RUST_FILES 2>&1 | grep "Diff in" || echo "  $RUST_FILES"
        echo ""
        echo "Please run 'make fmt' or 'cargo fmt --all', then commit the formatted code with:"
        echo "  git add <formatted_files>"
        echo "  git commit -m 'Format code'"
        echo "and try pushing again."
        echo "Note: Generated files in src/generated/ are excluded from formatting checks."
        exit 1
    fi
    
    cd "$REPO_ROOT"
else
    echo "No Rust files found in the latest commit to check."
fi

echo "✅ Committed code formatting check passed!"
exit 0