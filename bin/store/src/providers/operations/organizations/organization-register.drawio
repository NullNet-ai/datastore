        <mxCell id="T1lcw0PC1xroImWFmH2E-19" parent="1" style="text;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="CREATE OR REPLACE FUNCTION invalidate_patches_cache()&#xa;RETURNS TRIGGER AS $$&#xa;BEGIN&#xa;  UPDATE notif&#xa;  SET &quot;noCache&quot; = false&#xa;  WHERE &quot;table&quot; = &#39;patches&#39;;&#xa;&#xa;&#xa;  RETURN NEW;&#xa;END;&#xa;$$ LANGUAGE plpgsql;" vertex="1">
          <mxGeometry height="180" width="380" x="370" y="1530" as="geometry" />
        </mxCell>
        <mxCell id="T1lcw0PC1xroImWFmH2E-20" parent="1" style="text;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="CREATE OR REPLACE FUNCTION invalidate_patches_cache()&#xa;RETURNS TRIGGER AS $$&#xa;BEGIN&#xa;  UPDATE notif&#xa;  SET &quot;noCache&quot; = false&#xa;  WHERE &quot;table&quot; = &#39;patches&#39;;&#xa;&#xa;&#xa;  -- Notify external listeners (proxy app)&#xa;  PERFORM pg_notify(&#xa;    &#39;notif_changes&#39;,&#xa;    json_build_object(&#xa;      &#39;table&#39;, &#39;patches&#39;,&#xa;      &#39;action&#39;, &#39;invalidate_cache&#39;&#xa;    )::text&#xa;  );&#xa;&#xa;&#xa;  RETURN NULL;&#xa;END;&#xa;$$ LANGUAGE plpgsql;" vertex="1">
          <mxGeometry height="330" width="380" x="370" y="1120" as="geometry" />
        </mxCell>
        <mxCell id="T1lcw0PC1xroImWFmH2E-21" parent="1" style="rounded=0;whiteSpace=wrap;html=1;" value="Datastore&lt;div&gt;(define schema)&lt;/div&gt;" vertex="1">
          <mxGeometry height="60" width="120" x="790" y="1070" as="geometry" />
        </mxCell>
        <mxCell id="T1lcw0PC1xroImWFmH2E-22" parent="1" style="rounded=0;whiteSpace=wrap;html=1;" value="" vertex="1">
          <mxGeometry height="390" width="480" x="770" y="440" as="geometry" />
        </mxCell>
        <mxCell id="T1lcw0PC1xroImWFmH2E-23" parent="1" style="rounded=0;whiteSpace=wrap;html=1;" value="Proxy App" vertex="1">
          <mxGeometry height="60" width="120" x="780" y="570" as="geometry" />
        </mxCell>
        <UserObject label="import { Client } from &quot;pg&quot;;&#xa;&#xa;&#xa;const client = new Client({&#xa;  connectionString: process.env.DATABASE_URL,&#xa;});&#xa;&#xa;&#xa;await client.connect();&#xa;&#xa;&#xa;await client.query(&quot;LISTEN notif_changes&quot;);&#xa;&#xa;&#xa;client.on(&quot;notification&quot;, (msg) =&gt; {&#xa;  const payload = JSON.parse(msg.payload!);&#xa;&#xa;&#xa;  if (payload.table === &quot;patches&quot;) {&#xa;    console.log(&quot;Invalidate cache for patches&quot;);&#xa;    // 👉 clear cache / refresh data / re-fetch&#xa;  }&#xa;});" link="import { Client } from &quot;pg&quot;;&#xa;&#xa;&#xa;const client = new Client({&#xa;  connectionString: process.env.DATABASE_URL,&#xa;});&#xa;&#xa;&#xa;await client.connect();&#xa;&#xa;&#xa;await client.query(&quot;LISTEN notif_changes&quot;);&#xa;&#xa;&#xa;client.on(&quot;notification&quot;, (msg) =&gt; {&#xa;  const payload = JSON.parse(msg.payload!);&#xa;&#xa;&#xa;  if (payload.table === &quot;patches&quot;) {&#xa;    console.log(&quot;Invalidate cache for patches&quot;);&#xa;    // 👉 clear cache / refresh data / re-fetch&#xa;  }&#xa;});" id="T1lcw0PC1xroImWFmH2E-24">
          <mxCell parent="1" style="text;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1">
            <mxGeometry height="350" width="300" x="930" y="460" as="geometry" />
          </mxCell>
        </UserObject>
        <mxCell id="T1lcw0PC1xroImWFmH2E-25" edge="1" parent="1" source="T1lcw0PC1xroImWFmH2E-22" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0.5;entryY=0;entryDx=0;entryDy=0;entryPerimeter=0;" target="T1lcw0PC1xroImWFmH2E-7">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="T1lcw0PC1xroImWFmH2E-26" connectable="0" parent="T1lcw0PC1xroImWFmH2E-25" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];" value="Proxy app listens to notification table &quot;patches&quot;" vertex="1">
          <mxGeometry relative="1" x="-0.5728" y="-1" as="geometry">
            <mxPoint x="-97" y="126" as="offset" />
          </mxGeometry>
        </mxCell>
        <mxCell id="T1lcw0PC1xroImWFmH2E-32" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=#d6b656;fillColor=#fff2cc;align=center;verticalAlign=middle;rounded=0;" value="NOTE: Assuming the table examples above are correct and for the &quot;notif&quot; table you can create your own what&#39;s gonna be like where you store all your flags or notifs to help applications look up some config related data" vertex="1">
          <mxGeometry height="70" width="440" x="770" y="1170" as="geometry" />
        </mxCell>
        <mxCell id="T1lcw0PC1xroImWFmH2E-33" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=#82b366;fillColor=#d5e8d4;align=center;verticalAlign=middle;rounded=0;" value="For Testing purposes - just to prove it is working in DB" vertex="1">
          <mxGeometry height="30" width="510" x="880" y="1300" as="geometry" />
        </mxCell>
        <mxCell id="T1lcw0PC1xroImWFmH2E-34" parent="1" style="text;whiteSpace=wrap;fillColor=#000000;fontColor=#FFFFFF;strokeColor=#FFFFFF;" value="# CLI  - session 1&#xa;# from psql&#xa;&#xa;$: LISTEN notif_changes;" vertex="1">
          <mxGeometry height="100" width="230" x="875" y="1370" as="geometry" />
        </mxCell>
        <mxCell id="T1lcw0PC1xroImWFmH2E-35" parent="1" style="text;whiteSpace=wrap;fillColor=#000000;fontColor=#FFFFFF;strokeColor=#FFFFFF;" value="# CLI  - session 2&#xa;# from psql&#xa;&#xa;$: UPDATE patches SET status = &#39;active&#39; WHERE id = 1;" vertex="1">
          <mxGeometry height="100" width="230" x="1160" y="1370" as="geometry" />
        </mxCell>
        <mxCell id="T1lcw0PC1xroImWFmH2E-37" parent="1" style="text;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;" value="The flow is kinda like this&#xa;patches UPDATE&#xa;   ↓&#xa;trigger fires&#xa;   ↓&#xa;notif.noCache = false&#xa;   ↓&#xa;pg_notify(&#39;notif_changes&#39;)&#xa;   ↓&#xa;proxy receives event&#xa;   ↓&#xa;proxy clears / refreshes cache" vertex="1">
          <mxGeometry height="200" width="245" x="1000" y="1500" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
