        <mxCell id="T1lcw0PC1xroImWFmH2E-18" connectable="0" parent="T1lcw0PC1xroImWFmH2E-17" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];" value="after creating the function that you need, create now a trigger&amp;nbsp;&lt;div&gt;that points to the function and do some update operations&lt;/div&gt;" vertex="1">
