        <mxCell id="lnfCKG0mWKU1AnwFSKSK-93" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;&lt;span style=&quot;font-weight: 400;&quot;&gt;&lt;font&gt;-- Dynamic Construct for permitted Records&lt;/font&gt;&lt;/span&gt;&lt;/h1&gt;&lt;div&gt;&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;WITH permittedRecords AS (&lt;/h1&gt;&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;&amp;nbsp; SELECT&amp;nbsp;&lt;/h1&gt;&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;&amp;nbsp; -- role permissions - ALL fields&lt;/h1&gt;&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;&amp;nbsp; -- field permission - specific field&lt;/h1&gt;&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;&amp;nbsp; &amp;nbsp; CASE WHEN&amp;nbsp;&lt;/h1&gt;&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;&amp;nbsp; &lt;span style=&quot;white-space:pre&quot; class=&quot;Apple-tab-span&quot;&gt;&#x9;&lt;/span&gt;-- permission based expression&lt;/h1&gt;&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;&amp;nbsp; &lt;span style=&quot;white-space:pre&quot; class=&quot;Apple-tab-span&quot;&gt;&#x9;&#x9;&lt;/span&gt;FALSE -- READ (SL) -- Decrypt&lt;/h1&gt;&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;&amp;nbsp; &lt;span style=&quot;white-space:pre&quot; class=&quot;Apple-tab-span&quot;&gt;&#x9;&lt;/span&gt;THEN id ELSE NULL END as id,&lt;/h1&gt;&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;&amp;nbsp; &amp;nbsp; status,&lt;/h1&gt;&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;&amp;nbsp; &amp;nbsp; -- assuming the records has sensitivity_level&lt;/h1&gt;&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;&amp;nbsp; &amp;nbsp; FLOOR(1 + random() * 1000)::int as sensitivity_level -- OK &amp;nbsp;- X permissions - X Read, Decrypt&lt;/h1&gt;&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;&amp;nbsp; FROM samples WHERE&amp;nbsp;&lt;/h1&gt;&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;&amp;nbsp; -- record permission - A lot X&lt;/h1&gt;&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;&amp;nbsp; -- id NOT IN (&#39;ba803f1b-97b2-4f54-8085-3d82bc510a0d&#39;)&lt;/h1&gt;&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;&amp;nbsp; LIMIT 10&lt;/h1&gt;&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;)&lt;/h1&gt;&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;-- all the constructed statements from old implementation still as is&lt;/h1&gt;&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;SELECT * FROM permittedRecords AS samples&amp;nbsp;&lt;/h1&gt;&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;WHERE&amp;nbsp;&lt;/h1&gt;&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;-- assuming current logged in role sensitivity level&lt;/h1&gt;&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;samples.sensitivity_level &amp;gt;= 3&lt;/h1&gt;&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;LIMIT 20&lt;/h1&gt;&lt;/div&gt;" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;fillColor=#f5f5f5;fontColor=#333333;strokeColor=#666666;fontSize=8;" vertex="1" parent="1">
